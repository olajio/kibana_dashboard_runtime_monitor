{
  "policy": {
    "_meta": {
      "description": "Retention for dashboard health results: roll over daily or at 5gb, keep 180 days."
    },
    "phases": {
      "hot": {
        "actions": {
          "rollover": {
            "max_age": "1d",
            "max_primary_shard_size": "5gb"
          }
        }
      },
      "delete": {
        "min_age": "180d",
        "actions": {
          "delete": {}
        }
      }
    }
  }
}
